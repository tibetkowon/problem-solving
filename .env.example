DOCKER_USERNAME=your-dockerhub-username
MYSQL_ROOT_PASSWORD=rootpassword
MYSQL_DATABASE=problemsolving
MYSQL_USER=appuser
MYSQL_PASSWORD=apppassword

# 로컬 개발 실행 순서:

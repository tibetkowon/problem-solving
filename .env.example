# Docker Hub 아이디 — GitHub Actions CI/CD에서 이미지 push/pull 시 사용
# 로컬 bootRun 실행 시에는 불필요
DOCKER_USERNAME=your-dockerhub-username

MYSQL_ROOT_PASSWORD=rootpassword
MYSQL_DATABASE=problemsolving
MYSQL_USER=appuser
MYSQL_PASSWORD=apppassword

# 로컬 개발 실행 순서:
# 1. cp .env.example .env  (값 필요 시 수정)
# 2. docker compose up mysql redis -d
# 3. ./gradlew :api:bootRun
# 4. ./gradlew :batch:bootRun  (선택)
